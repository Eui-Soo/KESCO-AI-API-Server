# Application
APP_NAME=KESCO-DigitalTwin
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Logging
LOG_BACKUP_DAYS=60
LOG_DIR=log

# Files
FILES_DIR=files

# ESS
# Parquet 파일 저장 시 사용할 기본 ESS ID
# 실제 관제 DB에서 ess_id/site_id가 넘어오면 나중에 그 값으로 대체 가능
DEFAULT_ESS_ID=KESCO_ESS_001

# File retention
# preprocessed 데이터는 raw 데이터에서 다시 만들 수 있으므로 일정 기간 후 자동 삭제
PREPROCESSED_RETENTION_DAYS=60

# Scheduler
SCHEDULE_HOUR=0
SCHEDULE_MINUTE=0
SCHEDULE_SECOND=30

# Database - AI result DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kesco_digitaltwin
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Remote Database - monitoring system source DB
DB_REMOTE_HOST=monitoring_db_host
DB_REMOTE_PORT=5432
DB_REMOTE_NAME=monitoring_db_name
DB_REMOTE_USER=readonly_user
DB_REMOTE_PASSWORD=readonly_password