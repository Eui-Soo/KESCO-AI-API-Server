# Application
APP_NAME=KESCO-DigitalTwin
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Logging
LOG_BACKUP_DAYS=60
LOG_DIR=log

# Files
FILES_DIR=files

# Scheduler
SCHEDULE_HOUR=0
SCHEDULE_MINUTE=0
SCHEDULE_SECOND=30

# Database - AI result DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kesco_digitaltwin
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Remote Database - monitoring system source DB
DB_REMOTE_HOST=monitoring_db_host
DB_REMOTE_PORT=5432
DB_REMOTE_NAME=monitoring_db_name
DB_REMOTE_USER=readonly_user
DB_REMOTE_PASSWORD=readonly_password